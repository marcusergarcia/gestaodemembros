rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Usuarios ficam na raiz - cada usuario tem um igrejaId
    match /usuarios/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regra principal: tudo dentro de /igrejas/{igrejaId} so pode ser acessado
    // por usuarios que pertencem a essa igreja
    match /igrejas/{igrejaId} {
      // Funcao helper para verificar se o usuario pertence a igreja
      function userBelongsToChurch() {
        return request.auth != null 
          && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
          && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.igrejaId == igrejaId;
      }
      
      // Funcao helper para verificar nivel de acesso
      function getUserAccessLevel() {
        return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.nivelAcesso;
      }
      
      // Dados da igreja
      allow read: if userBelongsToChurch();
      allow write: if userBelongsToChurch() && getUserAccessLevel() == "admin";
      
      // UNIDADES - Esta regra estava faltando!
      match /unidades/{unidadeId} {
        allow read: if userBelongsToChurch();
        allow create: if userBelongsToChurch() && getUserAccessLevel() == "admin";
        allow update, delete: if userBelongsToChurch() && getUserAccessLevel() == "admin";
      }
      
      // Membros
      match /membros/{membroId} {
        allow read: if userBelongsToChurch();
        allow create: if userBelongsToChurch();
        allow update, delete: if userBelongsToChurch()
          && getUserAccessLevel() in ["admin", "lider"];
      }
      
      // Grupos
      match /grupos/{grupoId} {
        allow read: if userBelongsToChurch();
        allow create: if userBelongsToChurch();
        allow update, delete: if userBelongsToChurch()
          && getUserAccessLevel() in ["admin", "lider"];
      }
      
      // Acompanhamentos
      match /acompanhamentos/{acompId} {
        allow read: if userBelongsToChurch();
        allow create: if userBelongsToChurch()
          && getUserAccessLevel() in ["admin", "lider", "obreiro"];
        allow update, delete: if userBelongsToChurch()
          && getUserAccessLevel() == "admin";
      }
    }
  }
}
