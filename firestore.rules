rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // REGRAS DE SEGURANÇA DO FIRESTORE
    // ========================================
    
    // Regra padrão: usuários autenticados podem ler/escrever
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // ========================================
    // FORMULÁRIOS PÚBLICOS (SEM AUTENTICAÇÃO)
    // ========================================
    
    // Permite leitura pública das informações básicas da igreja
    match /igrejas/{igrejaId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      // Permite leitura pública das unidades (para selecionar no formulário)
      match /unidades/{unidadeId} {
        allow read: if true;
        allow write: if request.auth != null;
        
        // MEMBROS - Permite criação pública (formulário público de cadastro)
        match /membros/{membroId} {
          // Qualquer pessoa pode criar um novo membro (formulário público)
          allow create: if true
            && request.resource.data.criadoPor == "formulario_publico"
            && request.resource.data.nome is string
            && request.resource.data.telefone is string;
          
          // Leitura e outras operações requerem autenticação
          allow read, update, delete: if request.auth != null;
        }
        
        // VISITANTES - Permite criação pública (formulário público de cadastro)
        match /visitantes/{visitanteId} {
          // Qualquer pessoa pode criar um novo visitante (formulário público)
          allow create: if true
            && request.resource.data.criadoPor == "formulario_publico"
            && request.resource.data.nome is string
            && request.resource.data.telefone is string;
          
          // Leitura e outras operações requerem autenticação
          allow read, update, delete: if request.auth != null;
        }
      }
    }
    
    // Coleção de usuários - apenas autenticados
    match /usuarios/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}
