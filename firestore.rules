rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGRA SIMPLES PARA TESTE
    // Qualquer usuario autenticado pode ler e escrever em qualquer documento
    // ATENCAO: Use apenas para teste! Depois ative regras mais restritas.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
